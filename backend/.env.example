# ============================================
# TBM 음성 AI 시스템 환경 설정
# ============================================
# 이 파일을 .env로 복사하고 실제 값을 입력하세요
# cp .env.example .env

# 서버 설정
PORT=3000
NODE_ENV=development

# ============================================
# 데이터베이스 (네이버 클라우드 Cloud DB for MySQL)
# ============================================
DB_HOST=your-db-host.nclouddatabase.com
DB_PORT=3306
DB_NAME=tbm_system
DB_USER=your_username
DB_PASSWORD=your_password

# ============================================
# AI API 키
# ============================================
# Claude API (Anthropic) - 위험성평가 AI 분석용
# https://console.anthropic.com/ 에서 발급
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx

# ============================================
# 네이버 클라우드 CLOVA API
# ============================================
# CLOVA Speech (음성인식 STT)
# https://console.ncloud.com/naver-speech 에서 발급
CLOVA_SPEECH_CLIENT_ID=your_client_id
CLOVA_SPEECH_CLIENT_SECRET=your_client_secret

# CLOVA Voice (음성합성 TTS)
# https://console.ncloud.com/naver-voice 에서 발급
CLOVA_VOICE_CLIENT_ID=your_client_id
CLOVA_VOICE_CLIENT_SECRET=your_client_secret

# ============================================
# 네이버 클라우드 Object Storage (파일 저장)
# ============================================
NCP_ACCESS_KEY=your_access_key
NCP_SECRET_KEY=your_secret_key
NCP_BUCKET_NAME=tbm-files
NCP_REGION=kr-standard

# ============================================
# JWT 인증 (사용자 로그인용)
# ============================================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ============================================
# 기타 설정
# ============================================
# 로그 레벨: debug, info, warn, error
LOG_LEVEL=info

# 최대 파일 업로드 크기 (MB)
MAX_UPLOAD_SIZE=50

# 세션 만료 시간 (시간)
SESSION_TIMEOUT_HOURS=24
